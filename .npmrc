engine-strict=true

# Supply chain protection: only install package versions published at least 7 days ago.
# Bypass for a single install with --min-release-age=0, or add trusted packages below.
min-release-age=7
min-release-age-exclude[]=@expensify/*
min-release-age-exclude[]=expensify-common
min-release-age-exclude[]=react-native-onyx
min-release-age-exclude[]=eslint-config-expensify
