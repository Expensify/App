{
    "extends": "../../tsconfig.json",
    "compilerOptions": {
        "types": ["@types/bun"],
        "paths": {
            "@assets/*": ["../../assets/*"],
            "@components/*": ["../../src/components/*"],
            "@hooks/*": ["../../src/hooks/*"],
            "@libs/*": ["../../src/libs/*"],
            "@navigation/*": ["../../src/libs/Navigation/*"],
            "@scripts/*": ["../../scripts/*", "../../.github/scripts/*"],
            "@selectors/*": ["../../src/selectors/*"],
            "@src/*": ["../../src/*"],
            "@styles/*": ["../../src/styles/*"],
            "@userActions/*": ["../../src/libs/actions/*"]
        }
    },
    "include": ["src", "tests", "scripts"]
}
