{
    "extends": "../tsconfig.json",
    "compilerOptions": {
        "types": ["@types/bun"],
        "paths": {
            "@libs/*": ["./libs/*"],
            "@plugins/*": ["./plugins/*"],
            "@scripts/*": ["../scripts/*", "../.github/scripts/*"],
            "@src/*": ["../src/*"]
        }
    },
    "include": ["libs", "plugins", "stubs", "victory-chart-renderer"],
    "exclude": ["victory-chart-renderer/dist", "victory-chart-renderer/.dev"]
}
