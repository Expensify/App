{
    "compilerOptions": {
        "module": "node16",
        "moduleResolution": "node16",
        "target": "ES2023",
        "types": ["node"],
        "paths": {
            "@assets/*": ["../assets/*"],
            "@components/*": ["../src/components/*"],
            "@github/*": ["../.github/*"],
            "@hooks/*": ["../src/hooks/*"],
            "@libs/*": ["../src/libs/*"],
            "@navigation/*": ["../src/libs/Navigation/*"],
            "@pages/*": ["../src/pages/*"],
            "@prompts/*": ["../prompts/*"],
            "@scripts/*": ["../scripts/*", "../.github/scripts/*"],
            "@styles/*": ["../src/styles/*"],
            "@src/*": ["../src/*"],
            "@userActions/*": ["../src/libs/actions/*"]
        }
    }
}
