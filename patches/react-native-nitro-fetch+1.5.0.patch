+package com.margelo.nitro.nitrofetch
+
+import org.chromium.net.CronetEngine
+import java.util.Date
+
+/**
+ * Certificate pinning for the Cronet engines (Expensify Iteration 1 - NewDot).
+ *
+ * Patched into react-native-nitro-fetch via patch-package. Cronet uses its own BoringSSL trust stack
+ * and does NOT honor Android's network_security_config.xml, so public-key pins are applied directly
+ * to each CronetEngine.Builder here. Disabled in debug builds so local dev / proxy tooling keeps working.
+ *
+ * Each host pins the leaf SPKI hash (primary) plus its issuing intermediate CA SPKI hash (durable
+ * backup that survives leaf rotation). Keep in sync with config/certificatePinning/pins.json,
+ * android/app/src/main/res/xml/network_security_config.xml, CertificatePinning.kt and CertificatePinning.swift.
+ */
+internal object ExpensifyCertificatePins {
+  // 2100-01-01 UTC. Cronet requires a non-null pin expiration; rotation is managed via app updates.
+  private val PIN_EXPIRATION = Date(4102444800000L)
+
+  private fun decode(base64Hash: String): ByteArray = android.util.Base64.decode(base64Hash, android.util.Base64.DEFAULT)
+
+  fun apply(builder: CronetEngine.Builder) {
+    if (BuildConfig.DEBUG) {
+      return
+    }
+
+    // Cronet bypasses configured pins for locally installed trust anchors by default.
+    // Disable that bypass in release builds so an installed interception CA cannot defeat pinning.
+    builder.enablePublicKeyPinningBypassForLocalTrustAnchors(false)
+
+    val expensifyCom = setOf(decode("cSP5K9Slk59AgwZPst+dLPuNE+ZhypUlYRQNW1XC/fc="), decode("brzvtCELCIZUo4sD/qPX0ccRtPsd3DY6RfmxpOU9oB4="))
+    val newExpensify = setOf(decode("G2v6PWWl92F5vVHCtAYwScBHqNtPMkxb++SFoBJq5F4="), decode("kIdp6NNEd8wsugYyyIYFsi1ylMCED3hZbSR8ZFsa/A4="))
+    val integrations = setOf(decode("7D0dEgdEKEMYRTgVwvnhJv19B4apk0QM/GPnRAKRGUs="), decode("AlSQhgtJirc8ahLyekmtX+Iw+v46yPYRLJt9Cq1GlB0="))
+    val travel = setOf(decode("Qb3qmTdRt/xHEN5PVtn+YhKoGqF/lhRX88cSFuSCJqM="), decode("kIdp6NNEd8wsugYyyIYFsi1ylMCED3hZbSR8ZFsa/A4="))
+    val cloudfront = setOf(decode("P9HBoLji8YncXSnb0AnAm72fJO/vpmxZrsl4fvUBkxc="), decode("DxH4tt40L+eduF6szpY6TONlxhZhBd+pJ9wbHlQ2fuw="))
+
+    builder.addPublicKeyPins("www.expensify.com", expensifyCom, false, PIN_EXPIRATION)
+    builder.addPublicKeyPins("secure.expensify.com", expensifyCom, false, PIN_EXPIRATION)
+    builder.addPublicKeyPins("staging.expensify.com", expensifyCom, false, PIN_EXPIRATION)
+    builder.addPublicKeyPins("staging-secure.expensify.com", expensifyCom, false, PIN_EXPIRATION)
+    builder.addPublicKeyPins("new.expensify.com", newExpensify, false, PIN_EXPIRATION)
+    builder.addPublicKeyPins("staging.new.expensify.com", newExpensify, false, PIN_EXPIRATION)
+    builder.addPublicKeyPins("integrations.expensify.com", integrations, false, PIN_EXPIRATION)
+    builder.addPublicKeyPins("travel.expensify.com", travel, false, PIN_EXPIRATION)
+    builder.addPublicKeyPins("staging.travel.expensify.com", travel, false, PIN_EXPIRATION)
+    builder.addPublicKeyPins("d2k5nsl2zxldvw.cloudfront.net", cloudfront, false, PIN_EXPIRATION)
+  }
+}
