+void BaseRuntimeAwareCache::MainRuntimeWatcher::onRuntimeDestroyed(
+    jsi::Runtime * /*rt*/) {
+  // The primary jsi::Runtime is going away. Any jsi::Object/jsi::Function
+  // still held by RuntimeAwareCache<T>::_primaryCache from now on points
+  // into freed memory - destroying them would dereference the dead Runtime.
+  // We flip the flag so ~RuntimeAwareCache can intentionally leak those
+  // entries instead of crashing on segfault.
+  BaseRuntimeAwareCache::_mainRuntimeAlive.store(false);
+  BaseRuntimeAwareCache::_mainRuntime = nullptr;
+}
+
+void BaseRuntimeAwareCache::setMainJsRuntime(jsi::Runtime *rt) {
+  _mainRuntime = rt;
+  if (rt != nullptr) {
+    _mainRuntimeAlive.store(true);
+    RuntimeLifecycleMonitor::addListener(*rt, &_mainRuntimeWatcher);
+  } else {
+    _mainRuntimeAlive.store(false);
+  }
+}
 
 } // namespace RNJsi
