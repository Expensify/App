+        id
+    }
+
+    if (modifiedId != android.R.id.paste) {
+      return super.onTextContextMenuItem(modifiedId)
+    }
+
+    val clipboardManager = getContext().getSystemService(Context.CLIPBOARD_SERVICE) as ClipboardManager
+
+    val clip = clipboardManager.primaryClip ?: return false
+    val uriItems = mutableListOf<Pair<String, String>>()
+
+    for (i in 0 until clip.itemCount) {
+        val item = clip.getItemAt(i)
+        val itemUri = item.uri
+        val itemIntent = item.intent
+
+        // Prefer file/content payloads over text payloads when both are present so copied files
+        // do not get downgraded to their string contents.
+        itemUri?.let { uri ->
+            uriItems += Pair(mimeTypeForClipUri(clip, i, uri), uri.toString())
+        }
+
+        // Intent payloads (rare, but valid clipboard data)
+        itemIntent?.let { intent ->
+            uriItems += Pair("application/vnd.android.intent", intent.toUri(Intent.URI_INTENT_SCHEME))
+        }
+
+        if (itemUri != null || itemIntent != null) {
+            continue
+        }
+    }
+
+    // Only consume the paste when there is at least one URI item (file/content).
+    // Text-only paste is left to Android so it inserts the text.
+    if (uriItems.isNotEmpty() && pasteWatcher != null) {
+      pasteWatcher?.onPaste(uriItems)
+      return true
+    }
+
+    return super.onTextContextMenuItem(modifiedId)
+  }
+
+  private fun mimeTypeForClipUri(clip: ClipData, itemIndex: Int, uri: Uri): String {
+    val description = clip.description
+    val descriptionMime = runCatching { description.getMimeType(itemIndex) }.getOrNull()
+    if (!descriptionMime.isNullOrEmpty() && descriptionMime != ClipDescription.MIMETYPE_TEXT_URILIST) {
+      return descriptionMime
+    }
+
+    val fileName = displayNameForUri(uri) ?: uri.lastPathSegment
+    val extension = fileName?.substringAfterLast('.', missingDelimiterValue = "")?.lowercase(Locale.ROOT)
+    if (!extension.isNullOrEmpty()) {
+      val extensionMime = MimeTypeMap.getSingleton().getMimeTypeFromExtension(extension)
+      if (!extensionMime.isNullOrEmpty()) {
+        return extensionMime
+      }
+    }
+
+    return "application/octet-stream"
+  }
+
+  private fun displayNameForUri(uri: Uri): String? {
+    if (uri.scheme != ContentResolver.SCHEME_CONTENT) {
+      return null
+    }
+
+    val cursor = runCatching {
+      context.contentResolver.query(uri, arrayOf(android.provider.OpenableColumns.DISPLAY_NAME), null, null, null)
+    }.getOrNull()
+
+    cursor?.use { c ->
+      val nameIndex = c.getColumnIndex(android.provider.OpenableColumns.DISPLAY_NAME)
+      if (nameIndex < 0) {
+        return null
+      }
+
+      if (!c.moveToFirst()) {
+        return null
+      }
+
+      return c.getString(nameIndex)
+    }
+
+    return null
+  }
 
