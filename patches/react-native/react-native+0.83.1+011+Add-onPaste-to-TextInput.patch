+ /**
+  * Utility class for handling paste operations from UIPasteboard.
+  * Processes pasteboard items and returns them in a standardized format
+  * suitable for the TextInput onPaste event.
+  */
+ @interface RCTPasteHandlerUtil : NSObject
+ 
+ /**
+  * Process the UIPasteboard and returns an array of info dictionaries for pasted items.
+  *
+  * Each dictionary contains:
+  * - type: (NSString) the MIME type of the content.
+  * - data: (NSString) either the string content or a file:// URI for binary data.
+  *
+  * This method will process text, URLs, images, and other file types.
+  * Binary data (images, files) are written to temporary files and returned as file:// URIs.
+  *
+  * @param pasteboard The UIPasteboard instance to process.
+  * @return An array of info dictionaries with "type" and "data" keys.
+  */
+ + (NSArray<NSDictionary<NSString *, NSString *> *> *)itemInfosFromPasteboard:(UIPasteboard *)pasteboard;
+ 
+ /**
+  * Checks if the provided pasteboard has pasteable content.
+  *
+  * @param pasteboard The UIPasteboard instance to check.
+  * @return YES if there is content that can be pasted, NO otherwise.
+  */
+ + (BOOL)hasPasteableContent:(UIPasteboard *)pasteboard;
+ 
+ /**
+ * Checks whether the pasteboard contains text payloads.
+  *
+ * Used to decide whether TextInput should take the system text paste path.
+  *
+  * @param pasteboard The UIPasteboard instance to inspect.
+ * @return YES when clipboard contains text-like content, NO otherwise.
+  */
++ (BOOL)containsTextContent:(UIPasteboard *)pasteboard;
+
+/**
+ * Checks whether the pasteboard contains any non-text content that can be
+ * processed into file items.
+ *
+ * @param pasteboard The UIPasteboard instance to inspect.
+ * @return YES when clipboard has non-text items to process, NO otherwise.
+ */
++ (BOOL)containsProcessableNonTextContent:(UIPasteboard *)pasteboard;
+ 
+ @end
+ 
+ NS_ASSUME_NONNULL_END
+ 
