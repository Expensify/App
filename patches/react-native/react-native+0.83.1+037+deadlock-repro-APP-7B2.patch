+  dispatch_semaphore_wait(_started, DISPATCH_TIME_FOREVER);
+
+  dispatch_after(dispatch_time(DISPATCH_TIME_NOW, 3 * NSEC_PER_SEC), dispatch_get_global_queue(QOS_CLASS_DEFAULT, 0), ^{
