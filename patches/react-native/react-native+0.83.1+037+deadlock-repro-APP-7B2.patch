+    self->_deadlockConfirmed = YES;
+    NSLog(@"[DeadlockRepro] =============================================");
+    NSLog(@"[DeadlockRepro] DEADLOCK CONFIRMED (3s watchdog fired)");
+    NSLog(@"[DeadlockRepro] =============================================");
+    NSLog(@"[DeadlockRepro]");
+    NSLog(@"[DeadlockRepro] MAIN THREAD (pthread %p) is BLOCKED on:", (void *)self->_mainThread);
+    NSLog(@"[DeadlockRepro]   shared_lock(mutex_)");
+    NSLog(@"[DeadlockRepro]   inside: ComponentDescriptorRegistry::findComponentDescriptorByHandle_DO_NOT_USE_THIS_IS_BROKEN");
+    NSLog(@"[DeadlockRepro]   called from: CADisplayLink -> displayLinkTick -> callBrokenLookupForTesting");
+    NSLog(@"[DeadlockRepro]");
+    NSLog(@"[DeadlockRepro] BACKGROUND THREAD (pthread %p) is BLOCKED on:", (void *)self->_backgroundThread);
+    NSLog(@"[DeadlockRepro]   RCTUnsafeExecuteOnMainQueueSync (waiting for main thread)");
+    NSLog(@"[DeadlockRepro]   inside: constructCoordinator -> LegacyViewManagerInteropComponentDescriptor::ctor");
+    NSLog(@"[DeadlockRepro]   called from: ComponentDescriptorRegistry::add (HOLDS unique_lock on mutex_)");
+    NSLog(@"[DeadlockRepro]            <- ComponentDescriptorProviderRegistry::add");
+    NSLog(@"[DeadlockRepro]            <- _registerComponentIfPossible (Fallback 3: Paper Interop)");
+    NSLog(@"[DeadlockRepro]            <- clearDescriptorCacheForTesting");
+    NSLog(@"[DeadlockRepro]");
+    NSLog(@"[DeadlockRepro] CIRCULAR DEPENDENCY:");
+    NSLog(@"[DeadlockRepro]   Main thread wants shared_lock(mutex_) -> but BG thread holds unique_lock(mutex_)");
+    NSLog(@"[DeadlockRepro]   BG thread wants main queue (RCTUnsafeExecuteOnMainQueueSync) -> but main thread is blocked");
+    NSLog(@"[DeadlockRepro]");
+    NSLog(@"[DeadlockRepro] MATCHES SENTRY EVENT 531b37a537dd4bd9b7562f3c0ca71dc1 (APP-7B2):");
+    NSLog(@"[DeadlockRepro]   Thread 0 (main):  std::__1::shared_mutex::lock_shared -> findComponentDescriptorByHandle_DO_NOT_USE_THIS_IS_BROKEN -> RCTSurfacePresenter synchronouslyUpdateViewOnUIThread -> stepAnimations");
+    NSLog(@"[DeadlockRepro]   Thread 24 (JS):   RCTUnsafeExecuteOnMainQueueSync -> LegacyViewManagerInteropComponentDescriptor::ctor -> ComponentDescriptorRegistry::add -> _registerComponentIfPossible");
+    NSLog(@"[DeadlockRepro] =============================================");
+  });
+
+  NSLog(@"[DeadlockRepro] [BG] Background thread starting re-registration chain:");
+  NSLog(@"[DeadlockRepro] [BG] -> clearDescriptorCacheForTesting");
+  NSLog(@"[DeadlockRepro] [BG]   -> _registerComponentIfPossible (Fallback 3: legacy interop)");
+  NSLog(@"[DeadlockRepro] [BG]     -> ComponentDescriptorProviderRegistry::add");
+  NSLog(@"[DeadlockRepro] [BG]       -> ComponentDescriptorRegistry::add - acquires unique_lock(mutex_)");
+  NSLog(@"[DeadlockRepro] [BG]         -> LegacyViewManagerInteropComponentDescriptor constructor");
+  NSLog(@"[DeadlockRepro] [BG]           -> constructCoordinator -> RCTUnsafeExecuteOnMainQueueSync (WILL BLOCK)");
+  NSLog(@"[DeadlockRepro] [BG] This matches Sentry Thread 24: _registerComponentIfPossible -> add -> add -> ctor -> RCTUnsafeExecuteOnMainQueueSync");
+
+  [_factory clearDescriptorCacheForTesting];
+
+  _deadlockConfirmed = YES;
+  NSLog(@"[DeadlockRepro] [BG] Re-registration finished - deadlock did NOT occur");
+
+  dispatch_async(dispatch_get_main_queue(), ^{
+    [self->_displayLink invalidate];
+    self->_displayLink = nil;
+  });
+}
+
