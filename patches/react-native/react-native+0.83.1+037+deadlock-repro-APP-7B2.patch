+  _signaled = NO;
+  _mainThreadStackLogged = NO;
+  _deadlockConfirmed = NO;
+  _backgroundThread = pthread_self();
+
+  dispatch_async(dispatch_get_main_queue(), ^{
+    NSLog(@"[DeadlockRepro] [MAIN] Registering CADisplayLink on main RunLoop");
