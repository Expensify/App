+  if (!_mainThreadStackLogged) {
+    _mainThreadStackLogged = YES;
+    NSLog(@"[DeadlockRepro] [MAIN] -> displayLinkTick - about to call callBrokenLookupForTesting in tight loop (simulates animation tick)");
