+    // scope whose destructor fires onRuntimeDestroyed when the runtime is torn
+    // down. This is the only callback skia gets for primary-runtime teardown.
+    RuntimeLifecycleMonitor::addListener(*rt, &_mainRuntimeWatcher);
+  } else {
+    _mainRuntimeAlive.store(false);
+  }
